generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sport {
  PICKLEBALL
  BADMINTON
}

enum TournamentStatus {
  DRAFT
  CONFIGURED
  SCHEDULED
  LOCKED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum Role {
  ADMIN
  SCOREKEEPER
  DISPLAY
}

enum DivisionType {
  MENS_SINGLES
  WOMENS_SINGLES
  KIDS_SINGLES
  MENS_DOUBLES
  WOMENS_DOUBLES
  KIDS_DOUBLES
  MIXED_DOUBLES
}

enum TeamStatus {
  ACTIVE
  WITHDRAWN
  DISQUALIFIED
}

enum MatchStatus {
  SCHEDULED
  WARMUP
  IN_PROGRESS
  PAUSED
  COMPLETED
  DISPUTED
  REOPENED
  CANCELLED
}

enum GameStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  REOPENED
}

enum ScoreEventType {
  MATCH_STARTED
  GAME_STARTED
  POINT_AWARDED
  POINT_REMOVED
  UNDO
  SIDE_OUT
  SERVER_CHANGED
  GAME_COMPLETED
  MATCH_COMPLETED
  MATCH_REOPENED
  ADMIN_CORRECTION
  NOTE_ADDED
}

enum SourceOutcome {
  WINNER
  LOSER
  BYE
}

enum DisplayMode {
  COURT
  MATCH
  DIVISION
  OVERVIEW
}

enum ImportStatus {
  PENDING
  VALIDATING
  READY
  IMPORTED
  FAILED
}

enum ServiceSide {
  LEFT
  RIGHT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships           TournamentMember[]
  assignedMatches       Match[]            @relation("AssignedScorekeeper")
  activeScorekeeperLocks Match[]           @relation("ActiveScorekeeper")
  scoreEvents           ScoreEvent[]
  auditLogs             AuditLog[]
  imports               ImportBatch[]
  lockedRules           ScoringRules[]     @relation("RulesLockedBy")
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  sport       Sport
  status      TournamentStatus @default(DRAFT)
  venueName   String?
  startsAt    DateTime?
  endsAt      DateTime?
  publicEnabled Boolean        @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members          TournamentMember[]
  divisions        Division[]
  players          Player[]
  teams            Team[]
  courts           Court[]
  matches          Match[]
  standings        Standing[]
  scoringRules     ScoringRules[]
  scheduleSettings ScheduleSettings[]
  playoffSettings  PlayoffSettings[]
  displayDevices   DisplayDevice[]
  importBatches    ImportBatch[]
  auditLogs        AuditLog[]

  @@index([status])
  @@index([sport])
}

model TournamentMember {
  id           String     @id @default(cuid())
  tournamentId String
  userId       String
  role         Role
  createdAt    DateTime   @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId, role])
  @@index([userId])
}

model Division {
  id           String       @id @default(cuid())
  tournamentId String
  name         String
  type         DivisionType
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tournament       Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams            Team[]
  matches          Match[]
  standings        Standing[]
  scoringRules     ScoringRules[]
  scheduleSettings ScheduleSettings[]
  playoffSettings  PlayoffSettings?

  @@unique([tournamentId, type])
  @@index([tournamentId, active])
}

model Player {
  id           String   @id @default(cuid())
  tournamentId String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  ageGroup     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams      TeamPlayer[]

  @@index([tournamentId, lastName, firstName])
  @@index([tournamentId, email])
}

model Team {
  id           String     @id @default(cuid())
  tournamentId String
  divisionId   String
  name         String
  seed         Int?
  status       TeamStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tournament Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division     @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  players    TeamPlayer[]
  teamAMatches Match[]    @relation("TeamAMatch")
  teamBMatches Match[]    @relation("TeamBMatch")
  wonMatches   Match[]    @relation("WinningTeam")
  servedGames  Game[]     @relation("ServingTeam")
  wonGames     Game[]     @relation("GameWinningTeam")
  scoreEvents  ScoreEvent[]
  standings    Standing[]

  @@unique([divisionId, name])
  @@index([tournamentId])
  @@index([divisionId, seed])
}

model TeamPlayer {
  id       String @id @default(cuid())
  teamId   String
  playerId String
  position Int

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@unique([teamId, position])
  @@index([playerId])
}

model Court {
  id           String  @id @default(cuid())
  tournamentId String
  name         String
  number       Int
  active       Boolean @default(true)

  tournament     Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches        Match[]
  displayDevices DisplayDevice[]
  scorekeeperAccessLinks ScorekeeperAccessLink[]

  @@unique([tournamentId, number])
}

model ScorekeeperAccessLink {
  id           String   @id @default(cuid())
  tournamentId String
  courtId      String
  label        String
  tokenHash    String   @unique
  active       Boolean  @default(true)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([tournamentId, courtId, active])
}

model Match {
  id           String      @id @default(cuid())
  tournamentId String
  divisionId   String
  courtId      String?
  roundName    String
  matchNumber  Int
  bracketSlot  String?
  teamAId      String?
  teamBId      String?
  teamASourceMatchId String?
  teamASourceOutcome SourceOutcome?
  teamBSourceMatchId String?
  teamBSourceOutcome SourceOutcome?
  winnerTeamId String?
  status       MatchStatus @default(SCHEDULED)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  assignedScorekeeperId String?
  activeScorekeeperId   String?
  scoreLockExpiresAt    DateTime?
  scoreVersion          Int         @default(0)
  currentGameNumber     Int         @default(1)
  displayLabel          String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  court      Court?     @relation(fields: [courtId], references: [id], onDelete: SetNull)
  teamA      Team?      @relation("TeamAMatch", fields: [teamAId], references: [id], onDelete: SetNull)
  teamB      Team?      @relation("TeamBMatch", fields: [teamBId], references: [id], onDelete: SetNull)
  teamASourceMatch Match? @relation("TeamASourceMatch", fields: [teamASourceMatchId], references: [id], onDelete: SetNull)
  teamASourceChildren Match[] @relation("TeamASourceMatch")
  teamBSourceMatch Match? @relation("TeamBSourceMatch", fields: [teamBSourceMatchId], references: [id], onDelete: SetNull)
  teamBSourceChildren Match[] @relation("TeamBSourceMatch")
  winnerTeam Team?      @relation("WinningTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  assignedScorekeeper User? @relation("AssignedScorekeeper", fields: [assignedScorekeeperId], references: [id], onDelete: SetNull)
  activeScorekeeper   User? @relation("ActiveScorekeeper", fields: [activeScorekeeperId], references: [id], onDelete: SetNull)
  games       Game[]
  scoreEvents ScoreEvent[]
  displayDevices DisplayDevice[]

  @@unique([divisionId, matchNumber])
  @@index([tournamentId, status])
  @@index([divisionId, roundName])
  @@index([courtId, scheduledAt])
  @@index([teamASourceMatchId])
  @@index([teamBSourceMatchId])
}

model Game {
  id           String     @id @default(cuid())
  matchId      String
  gameNumber   Int
  teamAScore   Int        @default(0)
  teamBScore   Int        @default(0)
  servingTeamId String?
  serverNumber Int?
  firstServerExceptionActive Boolean @default(false)
  serviceSide ServiceSide?
  winnerTeamId String?
  status       GameStatus @default(NOT_STARTED)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  match       Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  servingTeam Team? @relation("ServingTeam", fields: [servingTeamId], references: [id], onDelete: SetNull)
  winnerTeam  Team? @relation("GameWinningTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  scoreEvents ScoreEvent[]

  @@unique([matchId, gameNumber])
}

model ScoreEvent {
  id              String         @id @default(cuid())
  matchId         String
  gameId          String?
  eventType       ScoreEventType
  teamId          String?
  previousStateJson Json
  newStateJson      Json
  createdByUserId   String?
  reason            String?
  createdAt         DateTime @default(now())

  match         Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  game          Game? @relation(fields: [gameId], references: [id], onDelete: SetNull)
  team          Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt])
  @@index([gameId])
}

model Standing {
  id                String   @id @default(cuid())
  tournamentId      String
  divisionId        String
  teamId            String
  matchesPlayed     Int      @default(0)
  wins              Int      @default(0)
  losses            Int      @default(0)
  gamesWon          Int      @default(0)
  gamesLost         Int      @default(0)
  pointsFor         Int      @default(0)
  pointsAgainst     Int      @default(0)
  pointDifferential Int      @default(0)
  rank              Int?
  tieBreakerJson    Json?
  updatedAt         DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([divisionId, teamId])
  @@index([tournamentId, divisionId, rank])
}

model ScoringRules {
  id             String   @id @default(cuid())
  tournamentId   String
  divisionId     String?
  sport          Sport
  scoringType    String
  pointsToWin    Int
  winBy          Int
  pointCap       Int?
  bestOf         Int
  showServerNumber Boolean @default(false)
  rulesJson      Json?
  lockedAt       DateTime?
  lockedByUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division?  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  lockedBy   User?      @relation("RulesLockedBy", fields: [lockedByUserId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, divisionId])
  @@index([sport])
}

model ScheduleSettings {
  id           String  @id @default(cuid())
  tournamentId String
  divisionId   String?
  format       String
  numberOfPools Int?
  randomizeTeams Boolean @default(false)
  randomizeMatches Boolean @default(false)
  avoidBackToBack Boolean @default(true)
  matchDurationMinutes Int @default(30)
  breakBetweenMatchesMinutes Int @default(5)
  settingsJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division?  @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, divisionId])
}

model PlayoffSettings {
  id                 String @id @default(cuid())
  tournamentId       String
  divisionId         String @unique
  teamsAdvancePerPool Int?
  totalTeamsAdvance   Int
  playoffFormat       String
  thirdPlaceMatch     Boolean @default(false)
  seedingMethod       String
  tieBreakerOrderJson Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
}

model DisplayDevice {
  id           String      @id @default(cuid())
  tournamentId String
  name         String
  tokenHash    String      @unique
  mode         DisplayMode
  courtId      String?
  matchId      String?
  divisionId   String?
  active       Boolean     @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime    @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  court      Court?     @relation(fields: [courtId], references: [id], onDelete: SetNull)
  match      Match?     @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([tournamentId, active])
}

model ImportBatch {
  id             String       @id @default(cuid())
  tournamentId   String
  uploadedByUserId String?
  fileName       String
  status         ImportStatus @default(PENDING)
  totalRows      Int          @default(0)
  successfulRows Int          @default(0)
  failedRows     Int          @default(0)
  errorsJson     Json?
  createdAt      DateTime     @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  uploadedBy User?      @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tournamentId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  tournamentId String
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  actor      User?      @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tournamentId, createdAt])
  @@index([entityType, entityId])
}
